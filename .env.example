# ─────────────────────────────────────────────
#  InvTrack — Environment Configuration
#  Copy this file to .env and edit as needed
# ─────────────────────────────────────────────

# Path to the SQLite database file
DB_PATH=inventory.db

# Server host and port
HOST=127.0.0.1
PORT=8000

# Set to "production" in prod — disables /docs in future builds
APP_ENV=development

# CORS allowed origins (comma-separated). Use * for open access in dev.
CORS_ORIGINS=*
